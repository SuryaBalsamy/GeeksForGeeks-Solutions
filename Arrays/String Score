class Solution {
    public int scoreOfString(String s) {

        char arr[]=s.toCharArray();
        int sum=0;

        for(int i=0;i<arr.length-1;i++)
        {
            int diff=arr[i+1]-arr[i];
            if(diff<0)
            {
                diff=diff*-1;
            }
            sum+=diff;
        }
        return sum;


        
    }
}
