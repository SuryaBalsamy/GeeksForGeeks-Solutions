class Solution {
    public int lengthOfLastWord(String s) {
        String a=s.trim();

        char arr[]=a.toCharArray();
        int count=0;

        for(int i=arr.length-1;i>=0;i--)
        {
            if(!(arr[i]==' '))
            {
                count++;
            }
            else
            {
                break;
            }
        }
        return count;
        
    }
}
